BT_NAME = "EmotiBot"

ble = bluetooth.BLE()
ble.active(False)
time.sleep_ms(500)
ble.active(True)
ble.config(gap_name=BT_NAME)

# NUS service: one TX characteristic with NOTIFY flag (ESP32 → phone)
#              one RX characteristic with WRITE  flag (phone → ESP32, unused but good practice)
_NUS_SERVICE_UUID = bluetooth.UUID("6E400001-B5A3-F393-E0A9-E50E24DCCA9E")
_TX_CHAR_UUID     = bluetooth.UUID("6E400003-B5A3-F393-E0A9-E50E24DCCA9E")  # ESP32 → phone
_RX_CHAR_UUID     = bluetooth.UUID("6E400002-B5A3-F393-E0A9-E50E24DCCA9E")  # phone → ESP32

_FLAG_NOTIFY = bluetooth.FLAG_NOTIFY
_FLAG_WRITE  = bluetooth.FLAG_WRITE

_tx_char = (_TX_CHAR_UUID, _FLAG_NOTIFY)
_rx_char = (_RX_CHAR_UUID, _FLAG_WRITE)
_nus_service = (_NUS_SERVICE_UUID, (_tx_char, _rx_char))

((tx_handle, rx_handle),) = ble.gatts_register_services((_nus_service,))

_connected    = False
_conn_handle  = None
_last_sent    = ""          # track last sent so we don't spam same emotion

def _ble_irq(event, data):
    global _connected, _conn_handle
    if event == 1:                          # _IRQ_CENTRAL_CONNECT
        _conn_handle = data[0]
        _connected   = True
        print("[BT] Phone connected — handle:", _conn_handle)
    elif event == 2:                        # _IRQ_CENTRAL_DISCONNECT
        _connected   = False
        _conn_handle = None
        print("[BT] Disconnected — re-advertising")
        _advertise()
    elif event == 3:                        # _IRQ_GATTS_WRITE (phone → ESP32, ignored)
        pass

ble.irq(_ble_irq)

def _advertise():
    name_bytes  = BT_NAME.encode()
    flags       = bytearray([0x02, 0x01, 0x06])
    short_name  = bytearray([len(name_bytes) + 1, 0x08]) + name_bytes
    full_name   = bytearray([len(name_bytes) + 1, 0x09]) + name_bytes
    adv_data    = flags + short_name + full_name
    ble.gap_advertise(50, adv_data=adv_data)
    print("[BT] Advertising as:", BT_NAME)

def bt_send(msg):
    """Send a string to the connected phone via BLE notify."""
    global _last_sent
    if _connected and _conn_handle is not None and msg != _last_sent:
        try:
            ble.gatts_notify(_conn_handle, tx_handle, msg.encode())
            _last_sent = msg
            print("[BT] Sent:", msg)
        except Exception as e:
            print("[BT] Send error:", e)

_advertise()

