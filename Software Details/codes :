from machine import Pin
import utime as time
 
# ── Motor pins ──────────────────────────────────────────────────────────────
#  L298N / L9110 style dual H-bridge
#  Motor A  →  IN1 / IN2
#  Motor B  →  IN3 / IN4
IN1 = Pin(27, Pin.OUT)
IN2 = Pin(26, Pin.OUT)
IN3 = Pin(25, Pin.OUT)
IN4 = Pin(33, Pin.OUT)
 
# ── IR line sensor ──────────────────────────────────────────────────────────
#  HIGH (1) = off-line  →  steer right
#  LOW  (0) = on-line   →  steer left
IR = Pin(18, Pin.IN)
 
# ── Motor helpers ───────────────────────────────────────────────────────────
def stop():
    IN1.value(0); IN2.value(0)
    IN3.value(0); IN4.value(0)
 
def forward():
    IN1.value(1); IN2.value(0)
    IN3.value(1); IN4.value(0)
 
def turn_right():
    """Left motor drives, right motor off → steers right."""
    IN1.value(1); IN2.value(0)   # left motor forward
    IN3.value(0); IN4.value(0)   # right motor stop
    time.sleep_ms(50)
    stop()
 
def turn_left():
    """Right motor drives, left motor off → steers left."""
    IN1.value(0); IN2.value(0)   # left motor stop
    IN3.value(1); IN4.value(0)   # right motor forward
    time.sleep_ms(50)
    stop()
 
# ── Main loop ────────────────────────────────────────────────────────────────
print("Version 1 — Basic line follower started")
 
while True:
    if IR.value() == 1:   # sensor off line → correct right
        turn_right()
    else:                 # sensor on line  → correct left
        turn_left()
 
    time.sleep_ms(50)

